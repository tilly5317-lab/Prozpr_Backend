# Force LF line endings for shell scripts (critical for Linux EC2 deployment)
*.sh text eol=lf

# Keep other text files auto-detected
* text=auto

# Explicitly set common text formats
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf

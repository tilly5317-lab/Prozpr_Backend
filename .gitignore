# Python — never commit bytecode or local venv (binary .pyc merge conflicts; huge diffs).
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc

# Virtual environment (must not be tracked)
.venv/
.venv-mac/
venv/
env/
.env/

# Environment variables / secrets (`.env.example` stays tracked)
.env
.env.*
!.env.example
*.pem

# Local SQLite / tooling
*.sqlite
*.sqlite3

# IDE / Editor
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~

# Linter / Formatter caches
.ruff_cache/
.mypy_cache/
.pyright/

# Distribution / Packaging
dist/
build/
*.egg-info/
*.egg

# SQLite databases
*.db

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Logs
*.log

# Pytest
.pytest_cache/
htmlcov/
.coverage
conftest.py

# Jupyter
.ipynb_checkpoints/

# Large data files (CSV)
*.csv

# Alembic auto-generated (keep versions/, ignore stamps)
# alembic/versions/ is tracked

# Superpowers (local only)
docs/superpowers/
**/docs/superpowers/
**/.claude/agents/
**/.claude/hooks/

# Shared .claude/commands — ignore all except the backend-root refresh-context command
**/.claude/commands/
!/.claude/
!/.claude/commands/
/.claude/commands/*
!/.claude/commands/refresh-context.md

# Agent audit runs (local test harness only)
Agent_audit/


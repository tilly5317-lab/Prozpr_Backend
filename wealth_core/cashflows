def generate_financial_projection(snapshot: ClientSnapshot) -> List[Dict]:
    rows = []
    # Initial Net Wealth (Opening Assets)
    opening_assets = snapshot.financial_assets - snapshot.financial_liabilities
    
    for i in range(snapshot.horizon_years + 1):
        year = snapshot.current_fy + i
        
        # 1. Income & Regular Expenses (Compounded Growth)
        inc_post_tax = (snapshot.annual_income * ((1 + snapshot.income_growth_rate) ** i)) * (1 - snapshot.tax_rate)
        exp = snapshot.annual_expenses * ((1 + snapshot.expense_growth_rate) ** i)
        
        # 2. One-offs & Goals
        in_val = sum(amt for y, amt in snapshot.one_off_inflows if y == year)
        out_val = sum(amt for y, amt in snapshot.one_off_outflows if y == year)
        
        goal_val = 0
        for g in snapshot.goals:
            if g['fy'] == year:
                goal_val += g['amt'] * ((1 + g['inf']) ** i)
        
        # 3. Asset Movement (ROI + Net Savings)
        roi_earned = opening_assets * snapshot.roi_rate
        net_savings = inc_post_tax - exp + in_val - out_val
        closing_assets = opening_assets + roi_earned + net_savings - goal_val
        
        rows.append({
            "year": year,
            "post_tax_income": round(inc_post_tax, 2),
            "expenses": round(exp, 2),
            "net_savings_before_goals": round(net_savings, 2),
            "goal_outflow": round(goal_val, 2),
            "opening_assets": round(opening_assets, 2),
            "roi_earned": round(roi_earned, 2),
            "closing_net_worth": round(closing_assets, 2)
        })
        
        # Closing of this year is opening of next
        opening_assets = closing_assets
        
    return rows


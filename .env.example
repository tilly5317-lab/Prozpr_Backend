# =============================================================================
# Database — use AWS RDS PostgreSQL in production (driver: asyncpg).
# Local SQLite files (e.g. wealth_agent.db) are rejected unless ALLOW_SQLITE=true.
# =============================================================================

# --- Option A: single URL (typical for RDS) ---
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@your-db.region.rds.amazonaws.com:5432/dbname?ssl=require

# --- Option B: discrete variables (password may need URL-encoding in Option A) ---
# POSTGRES_HOST=your-db.region.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_USER=app_user
# POSTGRES_PASSWORD=secret
# POSTGRES_DB=prozpr

# --- Local SQLite only (development; not for production) ---
# ALLOW_SQLITE=true
# DATABASE_URL=sqlite+aiosqlite:///./wealth_agent.db

# After deploy, apply migrations on RDS:
#   alembic upgrade head

# =============================================================================
# LLM — Anthropic. Invalid keys return 401.
# Each module has its own env var. Unset module vars fall back to ANTHROPIC_API_KEY.
# Use module-specific keys to (a) attribute spend per module on the Anthropic
# dashboard and (b) isolate rate-limit blast radius across features.
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-api03-...                # shared fallback
# INTENT_CLASSIFIER_API_KEY=sk-ant-api03-...        # intent_classifier
# MARKET_COMMENTARY_API_KEY=sk-ant-api03-...        # market commentary
# PORTFOLIO_QUERY_API_KEY=sk-ant-api03-...          # portfolio query
# ASSET_ALLOCATION_API_KEY=sk-ant-api03-...         # AA chat + AA pipeline + spine narrator
# RISK_PROFILING_API_KEY=sk-ant-api03-...           # risk profiling
# REBALANCING_API_KEY=sk-ant-api03-...              # rebalancing chat + chart picker
# ANSWER_FORMATTER_API_KEY=sk-ant-api03-...         # shared answer formatter (AA + rebalancing)
# FOLLOW_UP_API_KEY=sk-ant-api03-...                # follow-up suggestions
# GENERAL_CHAT_API_KEY=sk-ant-api03-...             # general chat
# CHART_SELECTOR_API_KEY=sk-ant-api03-...           # chart selector

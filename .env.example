# Copy to .env and fill values. Use UPPER_SNAKE names (recommended).

# false = no Postgres/RDS; app uses in-memory SQLite (good for deploy smoke tests when DB is unreachable).
# true = normal Postgres (DATABASE_URL or DB_*).
USE_DATABASE=true

# Option A — single URL (if set, it wins; leave empty to use Option B)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/Ailax

# Option B — AWS RDS (used only when DATABASE_URL is unset/empty; app builds DATABASE_URL)
DB_HOST=database-1.cvk6s2k08jru.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_USER=postgres
DB_NAME=postgres
# Retrieve the password from AWS Secrets Manager / RDS console / your team vault
DB_PASSWORD=your_retrieved_password
JWT_SECRET=your-secret-key-at-least-32-characters-long
ENCRYPTION_KEY=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

OPENAI_API_KEY=

# Anthropic (Claude) — optional shared fallback if a feature-specific key below is omitted.
ANTHROPIC_API_KEY=

# Per-feature keys (recommended for quotas / billing separation)
INTENT_CLASSIFIER_API_KEY=
MARKET_COMMENTARY_API_KEY=
PORTFOLIO_QUERY_API_KEY=
ASSET_ALLOCATION_API_KEY=
RISK_PROFILING_API_KEY=

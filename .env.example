# Copy to .env and fill values. Use UPPER_SNAKE names (recommended).

# Database: if DATABASE_URL is set (non-empty), it is used and POSTGRES_* is ignored.
# Most setups only need this line (must use postgresql+asyncpg:// for this app):
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/prozpr

# Option B — optional fallback only when DATABASE_URL is unset (e.g. split secrets in CI).
# Password can contain any characters; do not commit real values.
# POSTGRES_HOST=your-db.xxxxx.ap-south-1.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=postgres
# Aliases: DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME
JWT_SECRET=your-secret-key-at-least-32-characters-long
ENCRYPTION_KEY=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

OPENAI_API_KEY=

# Anthropic (Claude) — optional shared fallback if a feature-specific key below is omitted.
ANTHROPIC_API_KEY=

# Per-feature keys (recommended for quotas / billing separation)
INTENT_CLASSIFIER_API_KEY=
MARKET_COMMENTARY_API_KEY=
PORTFOLIO_QUERY_API_KEY=
ASSET_ALLOCATION_API_KEY=
RISK_PROFILING_API_KEY=

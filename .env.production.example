# =============================================================
# Prozpr Production Environment Variables
# =============================================================
# Copy this file to /home/ec2-user/.env.prozpr on your EC2 instance.
# CodeDeploy will copy it into the backend during deployment.
# =============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/prozpr

# --- Auth / Security ---
JWT_SECRET=GENERATE_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
ENCRYPTION_KEY=GENERATE_ANOTHER_SECURE_RANDOM_STRING

# --- CORS ---
ALLOWED_ORIGINS=https://yourdomain.com,http://YOUR_EC2_PUBLIC_IP

# --- AI / LLM Keys ---
ANTHROPIC_API_KEY=sk-ant-...
INTENT_CLASSIFIER_API_KEY=
MARKET_COMMENTARY_API_KEY=
PORTFOLIO_QUERY_API_KEY=
ASSET_ALLOCATION_API_KEY=
RISK_PROFILING_API_KEY=

# --- Optional ---
OPENAI_API_KEY=
